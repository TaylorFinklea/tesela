# Generated by Cargo
# will have compiled files and executables
debug
target

# iOS archive / export output (scripts/ios-testflight.sh)
/build/

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/


# Added by cargo

/target

# Git worktrees
.worktrees/
.claude/worktrees/

# Tesela runtime artifacts
*.db
*.db-shm
*.db-wal
.tesela/

# Test / local note data — use ~/z-temp/tesela-test as the mosaic for dev
notes/
attachments/

# Superpowers plugin cache
.superpowers/

# Claude Code runtime artifacts (scheduled task lock, etc.)
.claude/scheduled_tasks.lock

# Playwright test artifacts
.playwright-mcp/
phase3f-*.png
phase3g-*.png
phase3h-*.png
phase3i-*.png
logseq-*.png

# Local screen-recordings / repro artifacts
*.mov

# Node / pnpm cache
.pnpm-store/

# Local temp dirs (root and per-package)
.tmp/

# macOS Finder metadata
.DS_Store

# APNs auth keys (.p8) — SECRETS, never commit. Sign relay push JWTs;
# live in the macOS Keychain / CF Worker secrets, not the repo.
AuthKey_*.p8
*.p8

# Local archive snapshots
*.zip

# Claude Code local hook scripts
.claude/hooks/

# T9 redesign raw package (curated copy lives in .docs/ai/design/graphite/)
T9.zip
.tmp-t9/
