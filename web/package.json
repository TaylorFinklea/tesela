{
	"name": "web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"generate:commands": "node scripts/generate-command-manifest.mjs",
		"check:manifest": "node scripts/check-manifest-fresh.mjs",
		"test:unit": "node --test 'tests/unit/**/*.test.mjs'",
		"test:perf": "node tests/perf/run.mjs",
		"test:e2e": "node tests/e2e/run.mjs"
	},
	"devDependencies": {
		"@playwright/test": "^1.57.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^25.6.2",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"@codemirror/commands": "^6.10.3",
		"@codemirror/lang-markdown": "^6.5.0",
		"@codemirror/language": "^6.12.3",
		"@codemirror/search": "^6.6.0",
		"@codemirror/state": "^6.6.0",
		"@codemirror/view": "^6.41.0",
		"@noble/hashes": "^2.2.0",
		"@replit/codemirror-vim": "^6.3.0",
		"@tabler/icons-svelte": "^3.41.1",
		"@tanstack/svelte-query": "^6.1.14",
		"bits-ui": "^2.17.3",
		"fflate": "^0.8.3",
		"loro-crdt": "1.12.3",
		"lucide-svelte": "^1.0.1",
		"qrcode-svg": "^1.1.0"
	}
