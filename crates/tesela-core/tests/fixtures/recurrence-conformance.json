  "_client_extraction_contract": [
    "CLIENT-ONLY section — mixed \"<date phrase> <recurrence phrase>\" EXTRACTION",
    "(parseDateAndRecurrenceInput / Swift's DateParser.parse), not standalone",
    "parseRecurrenceInput. tesela_core::recurrence has no extraction concept, so unlike",
    "`cases` these are PINNED LITERALS (verified against the real web implementation),",
    "not derived from a Rust function — see the module docs in recurrence_conformance.rs.",
    "",
    "Case shape: { name, input, anchor_date, expected: { date, time, recurrence, field } | null }"
  ],
  "client_extraction_cases": [
    {
