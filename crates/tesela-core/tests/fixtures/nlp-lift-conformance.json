{
  "_contract": [
    "Shared inline-NLP-lift conformance fixture (tesela-pfix.3) — GENERATED by",
    "crates/tesela-core/tests/nlp_lift_conformance.rs. No Rust NLP-lift parser exists",
    "yet (blocked on tesela-ug7), so every case's `expected` is a PINNED LITERAL",
    "(computed from the real web detectTaskTokens, then copied in) rather than",
    "Rust-derived — see the module docs in nlp_lift_conformance.rs. Consumed by the",
    "same test (round-trip) plus the web (nlp-lift-conformance.test.mjs) and iOS",
    "(NLPLiftConformanceTests.swift) mirrors, which assert their REAL lift",
    "implementation (detectTaskTokens / InlineNLP.detectLifts) against these values.",
    "",
    "`registry` is ONE shared DetectSpec-shaped spec reused by every case: select",
    "`priority` (p1..p4) + date `deadline` (triggers due/deadline, also the sole",
    "date-typed property so it doubles as the bare-date default). `anchor_date` is",
    "the frozen \"now\" (2026-05-22, a Friday) both clients pass so relative phrases",
    "resolve identically.",
    "",
    "Case shape: { name, text, expected: { stripped, props: [{key, value}] } }"
  ],
  "registry": {
    "default_date_property": "deadline",
    "properties": [
      {
        "key": "priority",
        "value_type": "select",
        "choices": [
          "p1",
          "p2",
          "p3",
          "p4"
        ],
        "triggers": [
          "p1",
          "p2",
          "p3",
          "p4"
        ]
      },
      {
        "key": "deadline",
        "value_type": "date",
        "choices": [],
        "triggers": [
          "due",
          "deadline"
        ]
      }
    ]
  },
  "anchor_date": "2026-05-22",
  "cases": [
    {
      "name": "select_lift_basic",
      "text": "fix the bug p1",
      "expected": {
        "stripped": "fix the bug",
        "props": [
          {
            "key": "priority",
            "value": "p1"
          }
        ]
      }
    },
    {
      "name": "select_lift_p3",
      "text": "clean up p3",
      "expected": {
        "stripped": "clean up",
        "props": [
          {
            "key": "priority",
            "value": "p3"
          }
        ]
      }
    },
    {
      "name": "date_trigger_lift",
      "text": "email report due tomorrow",
      "expected": {
        "stripped": "email report",
        "props": [
          {
            "key": "deadline",
            "value": "2026-05-23"
          }
        ]
      }
    },
    {
      "name": "date_trigger_with_time",
      "text": "call vet due thu at 8",
      "expected": {
        "stripped": "call vet",
        "props": [
          {
            "key": "deadline",
            "value": "2026-05-28 08:00"
          }
        ]
      }
    },
    {
      "name": "bare_trailing_lift",
      "text": "buy milk tomorrow",
      "expected": {
        "stripped": "buy milk",
        "props": [
          {
            "key": "deadline",
            "value": "2026-05-23"
          }
        ]
      }
    },
    {
      "name": "bare_trailing_today_noon",
      "text": "call mom today noon",
      "expected": {
        "stripped": "call mom",
        "props": [
          {
            "key": "deadline",
            "value": "2026-05-22 12:00"
          }
        ]
      }
    },
    {
      "name": "bare_trailing_tomorrow_noon",
      "text": "ping team tomorrow noon",
      "expected": {
        "stripped": "ping team",
        "props": [
          {
            "key": "deadline",
            "value": "2026-05-23 12:00"
          }
        ]
      }
    },
    {
      "name": "bare_midprose_not_lifted",
      "text": "call her tomorrow about the launch",
      "expected": {
        "stripped": "call her tomorrow about the launch",
        "props": []
      }
    },
    {
      "name": "intent_word_lift",
      "text": "ping team on tuesday afternoon",
      "expected": {
        "stripped": "ping team on afternoon",
        "props": [
          {
            "key": "deadline",
            "value": "2026-05-26"
          }
        ]
      }
    },
    {
      "name": "url_embedded_priority_no_lift",
      "text": "check https://x.com/p1/doc",
      "expected": {
        "stripped": "check https://x.com/p1/doc",
        "props": []
      }
    },
    {
      "name": "wikilink_embedded_priority_no_lift",
      "text": "see [[p1 notes]]",
      "expected": {
        "stripped": "see [[p1 notes]]",
        "props": []
      }
    },
    {
      "name": "wikilink_embedded_date_no_lift",
      "text": "plan [[meeting tomorrow]]",
      "expected": {
        "stripped": "plan [[meeting tomorrow]]",
        "props": []
      }
    },
    {
      "name": "markdown_link_embedded_priority_no_lift",
      "text": "read [spec](https://x.com/p1/doc) today-ish",
      "expected": {
        "stripped": "read [spec](https://x.com/p1/doc) today-ish",
        "props": []
      }
    },
    {
      "name": "inline_code_embedded_priority_no_lift",
      "text": "run `p1` now",
      "expected": {
        "stripped": "run `p1` now",
        "props": []
      }
    },
    {
      "name": "combined_priority_and_trailing_date",
      "text": "fix parser p1 due tomorrow",
      "expected": {
        "stripped": "fix parser",
        "props": [
          {
            "key": "priority",
            "value": "p1"
          },
          {
            "key": "deadline",
            "value": "2026-05-23"
          }
        ]
      }
    },
    {
      "name": "combined_priority_and_bare_trailing_date",
      "text": "buy milk p2 tomorrow",
      "expected": {
        "stripped": "buy milk",
        "props": [
          {
            "key": "priority",
            "value": "p2"
          },
          {
            "key": "deadline",
            "value": "2026-05-23"
          }
        ]
      }
    }
  ]
}
