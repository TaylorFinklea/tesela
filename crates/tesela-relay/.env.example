# Copy to .env and fill in. Do NOT commit .env — it carries the
# admin token in plaintext.

# Admin token gates the `DELETE /admin/groups/{id}/register`
# hijack-recovery endpoint. Pick something long + random; you only
# need it when recovering from a hijacked group registration.
# Generate with:
#   openssl rand -base64 32
TESELA_RELAY_ADMIN_TOKEN=
