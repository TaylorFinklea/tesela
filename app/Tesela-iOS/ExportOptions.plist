<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- App Store Connect / TestFlight export. The archive is dev-signed; this
       step re-signs with the "Apple Distribution: Taylor Finklea (K7CBQW6MPG)"
       cert + an App Store provisioning profile (managed via automatic signing
       with -allowProvisioningUpdates). -->
  <key>method</key>
  <string>app-store-connect</string>
  <key>teamID</key>
  <string>K7CBQW6MPG</string>
  <key>signingStyle</key>
  <string>automatic</string>
  <key>destination</key>
  <string>export</string>
  <key>uploadSymbols</key>
  <true/>
  <!-- The script stamps CFBundleVersion itself (unique per upload), so don't
       let the exporter rewrite versions. -->
  <key>manageAppVersionAndBuildNumber</key>
  <false/>
</dict>
</plist>
